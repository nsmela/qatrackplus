POSTGRES_USER=change_me
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=qatrackplus
USE_DOCKER=true

# Add the hostname or IP address you will use to access QATrack+ here.
# For example: ALLOWED_HOSTS=localhost,127.0.0.1
ALLOWED_HOSTS=*

# -----------------------------------------------------------------------------
# Optional Database Settings
# -----------------------------------------------------------------------------
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# QATrack+ Application Settings
# -----------------------------------------------------------------------------
# Enable the internal issue tracker
# USE_ISSUES=True

# Set the timezone
# TIME_ZONE=America/Toronto

# -----------------------------------------------------------------------------
# Development & Debugging
# -----------------------------------------------------------------------------
# Enable Django debug mode (not safe for production!)
# DEBUG=False
# Enable the Django debug toolbar (requires django-debug-toolbar to be installed)
# DEBUG_TOOLBAR=False

# -----------------------------------------------------------------------------
# Email Settings (for notifications)
# -----------------------------------------------------------------------------
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your_username
# EMAIL_HOST_PASSWORD=your_password
